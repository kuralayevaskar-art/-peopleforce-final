# Copy this file to C:\OscarHR\config\application-secrets.properties and fill real values.
# Do not send the filled file to anyone.

# HR PostgreSQL on this Windows server
DB_URL=jdbc:postgresql://localhost:5432/hr_peopleops
DB_USERNAME=hr_user
DB_PASSWORD=CHANGE_ME_HR_DB_PASSWORD
DB_DRIVER=org.postgresql.Driver

# Active Directory / LDAP
AD_ENABLED=true
AD_HOST=10.1.10.11
AD_URL=ldap://10.1.10.11:389
AD_BASE_DN=DC=DMUK,DC=EDU
AD_BIND_DN=zkt@dmuk.edu.kz
AD_BIND_PASSWORD=CHANGE_ME_AD_SERVICE_PASSWORD
AD_BIND_DOMAIN=dmuk.edu.kz
AD_DEFAULT_DOMAIN=dmuk.edu.kz
AD_USER_FILTER=(sAMAccountName={0})
AD_GROUP_FILTER=(&(objectClass=group)(member={0}))

# AD provisioning
PROVISIONING_DRY_RUN=false
POWERSHELL_EXECUTABLE=powershell.exe
AD_TARGET_OU=OU=Staff,OU=DMUK,DC=DMUK,DC=EDU
AD_DEFAULT_DEPARTMENT=DMUK
AD_CHANGE_PASSWORD_AT_LOGON=false

# Microsoft 365 ADSync. Command runs remotely on 10.1.10.11.
M365_SYNC_ENABLED=true
M365_SYNC_HOST=10.1.10.11
M365_SYNC_USERNAME=dmuk\service-account
M365_SYNC_PASSWORD=CHANGE_ME_M365_SYNC_PASSWORD

# ZKTeco
ZKTECO_SYNC_ENABLED=true
ZKTECO_HOST=10.1.70.2
ZKTECO_PORT=5442
ZKTECO_DB_NAME=biosecurity-boot
ZKTECO_USERNAME=root
ZKTECO_PASSWORD=CHANGE_ME_ZKTECO_DB_PASSWORD
ZKTECO_PHOTO_ROOT=//10.1.70.2/C$/Program Files/ZKBioCVSecurity/service/zkbiosecurity/BioSecurityFile

# File storage
SYNOLOGY_ENABLED=false
SYNOLOGY_HOST=10.1.30.49
SYNOLOGY_ROOT_PATH=Z:\\Global\\people
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=

# Mail / SMTP
MAIL_ENABLED=true
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=zkt@dmuk.edu.kz
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM=zkt@dmuk.edu.kz
MAIL_STARTTLS=true

# Logs
LOG_PATH=C:/OscarHR/logs
